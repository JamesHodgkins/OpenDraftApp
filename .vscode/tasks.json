{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Run OpenDraft",
			"type": "shell",
			"command": "${workspaceFolder}/.venv/Scripts/python.exe",
			"args": [
				"main.py"
			],
			"isBackground": false,
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "Run OpenDraft (Auto-Reload)",
			"type": "shell",
			"command": "${workspaceFolder}/.venv/Scripts/watchfiles.exe",
			"args": [
				"${workspaceFolder}/.venv/Scripts/python.exe main.py",
				"--filter",
				"python"
			],
			"isBackground": true,
			"problemMatcher": [],
			"group": "build"
		}
	]
}
